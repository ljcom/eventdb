NODE_ENV=development
PORT=3000

# PostgreSQL connection (prefer DATABASE_URL)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/eventdb_core
DB_SSL=false

# EventDB defaults
DEFAULT_NAMESPACE_ID=default
EVENT_GENESIS_PREV_HASH=GENESIS
SEAL_GENESIS_PREV_HASH=SEAL_GENESIS

# Signature verification mode:
# - none: only checks signature field non-empty
# - hmac_sha256: verifies signature = hex(HMAC_SHA256(canonical_input, account_secret))
SIGNATURE_MODE=none

# JSON map account_id -> secret for SIGNATURE_MODE=hmac_sha256
# Example: {"acct-ops-01":"secret-ops","acct-seal-01":"secret-seal"}
ACCOUNT_SECRETS_JSON={}

# API security
# When true, all non-health endpoints require API key
API_AUTH_ENABLED=true

# Role keys
# - ingest: POST /v1/chains/:chainId/events
# - ops: POST /v1/seals/:chainId/build and /v1/snapshots/:chainId/build
# - verify: all /verify endpoints
# - admin: optional super key (works for all roles)
API_KEY_INGEST=replace-me-ingest
API_KEY_OPS=replace-me-ops
API_KEY_VERIFY=replace-me-verify
API_KEY_ADMIN=

# Rate limit (fixed window, in-memory)
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_INGEST=300
RATE_LIMIT_MAX_OPS=60
RATE_LIMIT_MAX_VERIFY=120

# Audit log (structured JSON to stdout)
AUDIT_LOG_ENABLED=true
